  "description": "Scaffold exam projects: EPMS (payroll), SIMS (stock inventory), SFMS — npx, pick a template, get backend + frontend + README + .env",
  "type": "module",
  "bin": {
    "create-exam-app": "bin/create-exam-app.mjs"
  },
